{
	"name": "web",
	"version": "0.0.0",
	"description": "ResumeLite — local-first resume builder",
	"author": "ResumeLite",
	"type": "module",
	"private": true,
	"main": "electron-dist/main.cjs",
	"scripts": {
		"build": "rimraf dist && vite build",
		"dev": "vite dev",
		"serve": "vite preview",
		"start": "vite preview",
		"typecheck": "tsgo --noEmit",
		"typecheck:strict": "tsc --noEmit",
		"electron:typecheck": "tsc --noEmit -p electron/tsconfig.json",
		"electron:build": "esbuild electron/main.ts --bundle --platform=node --format=cjs --external:electron --outfile=electron-dist/main.cjs",
		"package:desktop": "pnpm build && pnpm electron:build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack-desktop.ps1",
		"test": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage --passWithNoTests",
		"test:ci": "vitest run --coverage --reporter=default --reporter=github-actions --reporter=json --reporter=junit --outputFile.json=reports/vitest-results.json --outputFile.junit=reports/vitest-junit.xml --passWithNoTests",
		"lingui:extract": "lingui extract --clean --overwrite"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@lingui/core": "^6.4.0",
		"@lingui/react": "^6.4.0",
		"@phosphor-icons/react": "^2.1.10",
		"@react-pdf/renderer": "^4.5.1",
		"@resumelite/docx": "workspace:*",
		"@resumelite/fonts": "workspace:*",
		"@resumelite/import": "workspace:*",
		"@resumelite/pdf": "workspace:*",
		"@resumelite/schema": "workspace:*",
		"@resumelite/ui": "workspace:*",
		"@resumelite/utils": "workspace:*",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/react-form": "^1.33.0",
		"@tanstack/react-hotkeys": "^0.10.0",
		"@tanstack/react-query": "^5.101.2",
		"@tanstack/react-router": "^1.170.16",
		"@tiptap/extension-color": "^3.27.1",
		"@tiptap/extension-highlight": "^3.27.1",
		"@tiptap/extension-table": "^3.27.1",
		"@tiptap/extension-text-align": "^3.27.1",
		"@tiptap/extension-text-style": "^3.27.1",
		"@tiptap/pm": "^3.27.1",
		"@tiptap/react": "^3.27.1",
		"@tiptap/starter-kit": "^3.27.1",
		"@types/js-cookie": "^3.0.6",
		"@uiw/color-convert": "^2.10.3",
		"@uiw/react-color-colorful": "^2.10.3",
		"cmdk": "^1.1.1",
		"es-toolkit": "^1.49.0",
		"fuse.js": "^7.4.2",
		"immer": "^11.1.8",
		"js-cookie": "^3.0.8",
		"motion": "^12.42.0",
		"pdfjs-dist": "6.1.200",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-resizable-panels": "^4.12.0",
		"react-window": "^2.2.7",
		"react-zoom-pan-pinch": "^4.0.3",
		"sonner": "^2.0.7",
		"ts-pattern": "^5.9.0",
		"usehooks-ts": "^3.1.1",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@babel/core": "^8.0.1",
		"@lingui/babel-plugin-lingui-macro": "^6.4.0",
		"@lingui/cli": "^6.4.0",
		"@lingui/format-po": "^6.4.0",
		"@lingui/vite-plugin": "^6.4.0",
		"@resumelite/config": "workspace:*",
		"@rolldown/plugin-babel": "^0.2.3",
		"@tanstack/router-plugin": "^1.168.18",
		"@types/babel__core": "^7.20.5",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260628.1",
		"@vitejs/plugin-react": "^6.0.3",
		"babel-plugin-macros": "^3.1.0",
		"babel-plugin-react-compiler": "^1.0.0",
		"electron": "^43.0.0",
		"esbuild": "^0.28.1",
		"rcedit": "^5.0.2",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.3",
		"vite": "^8.1.0"
	}
}
